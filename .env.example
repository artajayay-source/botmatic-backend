# ============================================================
# BotMatic Backend — Environment Variables
# Copy file ini ke .env dan isi nilainya
# JANGAN commit file .env ke git!
# ============================================================

# PORT (Railway set otomatis, jangan diubah)
PORT=3000

# URL Frontend (untuk CORS - isi dengan domain Vercel kamu)
FRONTEND_URL=https://botmatic.vercel.app

# ============================================================
# FONNTE (WhatsApp Gateway)
# Dapatkan di: app.fonnte.com → Account Settings → Token
# ============================================================
FONNTE_TOKEN=qEMf4Fa2QCiSRL6smWjbT1BuSJbknM2G6xKRWv

# ============================================================
# ANTHROPIC (Claude AI)
# Dapatkan di: console.anthropic.com → API Keys
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================================
# SUPABASE (Database)
# Dapatkan di: supabase.com → Project Settings → API
# ============================================================
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXXXXX
